{
  "rules": {
    "board": {
      ".read": true,
      ".write": true
    },
    "presence": {
      ".read": true,
      ".write": true
    },
    "playerFruit": {
      ".read": true,
      ".write": true
    },
    "playerLastSeen": {
      ".read": true,
      ".write": true
    },
    "fruitCounter": {
      ".read": true,
      ".write": true
    },
    "memberProfiles": {
      ".read": true,
      ".write": false
    },
    "memberTotalScore": {
      ".read": true,
      ".write": true,
      "$uid": {
        ".validate": "newData.isNumber() && newData.val() >= 0"
      }
    },
    "members": {
      ".read": false,
      ".write": false
    },
    "memberNicknames": {
      ".read": false,
      ".write": false
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
